{%- from "govuk/components/tag/macro.njk" import govukTag -%}
{%- from "govuk/components/accordion/macro.njk" import govukAccordion -%}

{% from "macros/ncea-contribution.njk" import nceaContribution %}
{% from "macros/relation-tree.njk" import renderTree %}

{% if params.options and params.hasData %}  
  <div class='tab-content-container'>
    {% set hasParentRecords = params.datasets.showTopTree or false %}
    {% set hasChildRecords = params.datasets.showBottomTree or false %}
    {% set lineageRecords = [] %}
    {% for option in params.options %}
      {% set isParent = option.label === 'Parent record(s)' %}
      {% set isChild = option.label === 'Child record(s)' %}
      {% if option.label and option.label !== 'map' %}
        <div class='tab-content-row'>
          {% if option.label === 'nceaContribution' and params.assetPath %}
            {% if option.displayValue !== '' %}
              <h2 class='tab-content-label'></h2>
              <div class='tab-content-value'>{{nceaContribution (params.assetPath, option.displayValue )}}</div>
            {% endif %}          
          {% elseif isParent or isChild %} 

                {% if isParent %}                    
                    {% set parentRecords = option.rawValue or [] %} 
                    {% set lineageRecords = lineageRecords | merge({ parents: parentRecords }) %}
                   
                {% elseif isChild %}                  
                  {% set childRecords = option.rawValue or [] %}
                  {% set lineageRecords = lineageRecords | merge({ childs: childRecords }) %}
                  <h2 class='tab-content-label'>Related</h2>
                  {% if hasParentRecords or hasChildRecords %}                    
                   <div class="lineageContainer" id="lineageTree"> 
                          {% set parentRecords = lineageRecords['parents'] or [] %} 
                          {% set childRecords = lineageRecords['childs'] or [] %}
                          <div class="tree-container">
                            {# ---------- PARENTS (TOP) ---------- #}
                            <section class="parent-section">
                              {% if params.datasets.showTopTree %}
                                {% set hasParentRecords = true %}
                                <span class="visually-hidden">Parent Datasets</span> 
                                <div class="relation-top">
                                  {{ renderTree(params.datasets.topTree, params.homePage, "parent") }}
                                </div>
                              {% endif %}
                              </section>
                              {# ---------- CURRENT DATASET ---------- #}
                                <section class="section-title" >
                                  <div  class="current-dataset" >
                                    <span class="visually-hidden">Current Dataset</span>
                                    <span tabindex="0">{{ params.datasets.current.title }}</span>
                                  </div>
                                </section>
                                {# ---------- CHILDREN (BOTTOM) ---------- #}
                                {% if params.datasets.showBottomTree %}
                                  <section class="child-section">
                                    <div class="relation-bottom">
                                      {% set hasChildRecords = true %}
                                      <span class="visually-hidden">Child Datasets</span> 
                                      {{ renderTree(params.datasets.bottomTree, params.homePage, "child") }}
                                    </div>
                                  </section>
                                {% endif %}
                          </div>
                   </div>                      
                  {% endif %}
                  {% if not hasParentRecords and not hasChildRecords %}
                    {{ govukTag({
                      text: "Unavailable",
                      classes: "govuk-tag--grey tab-content-value__not-provided"
                    }) }}
                  {% endif %}  

                {% else %}
                {{ govukTag({
                  text: "Unavailable",
                  classes: "govuk-tag--grey tab-content-value__not-provided"
                }) }}
              {% endif %}
            
          {% else %}
            <h2 class='tab-content-label'>{{ option.label | safe }}</h2>
            {% if option.displayValue %}
              <span class='tab-content-value'>
                {{option.displayValue | safe}}
              </span>
            {% else %}
              {{govukTag({
                text: "Unavailable",
                classes: "govuk-tag--grey tab-content-value__not-provided"
              })}}
            {% endif %}
          {% endif %}

        </div>
      {% endif %}
      {% if option.label and option.label === 'map' and option.displayValue %}
        <div id="coordinate-map" class="detail-map" style="height: 335px;"></div>
      {% endif %}
    {% endfor %}
  </div>
{% endif %}