{% from "macros/card.njk" import card %}
{% from "govuk/components/button/macro.njk" import govukButton %}

{% extends "layout/default.njk" %}

{% block head %}
  {{ super() }}

    <meta name="description" content="Natural Capital and Ecosystem Assessment programme (NCEA) background, highlights and product brochure">
{% endblock %}

{% block content %}
  <div class="landingPage">
  <header class="landingPage__header full-width-banner" role="banner">
    <div class="landingPage__header-heading">
      <h1 class="govuk-heading-xl banner-container__heading-xl">{{ pageHeading }}</h1>
      <img alt="Department for Environment Food &amp; Rural Affairs Logo" src="{{ assetPath }}/images/NCEA-logo-landscape.webp" class="banner-container__ncea-logo">
      <link rel="stylesheet" href="{{ assetPath }}/css/categories_detail.css" >
    </div>
  </header>

  {% if category == 'marine' %}
      {% include "partials/categories_detail/marine.njk" %}
  {% elseif category == 'vegetation' %}  
      {% include "partials/categories_detail/vegetation.njk" %}
  {% elseif category == 'soilspeat' %}  
      {% include "partials/categories_detail/soils_peat.njk" %}
  {% elseif category == 'freshwater' %}  
      {% include "partials/categories_detail/fresh_water.njk" %}      
  {% elseif category == 'treeswoodland' %}  
      {% include "partials/categories_detail/trees_woodland.njk" %}
  {% elseif category == 'citizen-science' %}  
      {% include "partials/categories_detail/citizen_science.njk" %}      
  {% endif %}

{% endblock %}
